# =============================================
# Copiar este archivo a .env.local y completar
# =============================================

# --- SUPABASE ---
# Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- AZURE AD (Microsoft 365) ---
# Azure Portal > Microsoft Entra ID > App registrations > Arena Control
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- NEXTAUTH ---
# URL de tu app (localhost en desarrollo, URL de Vercel en producción)
NEXTAUTH_URL=http://localhost:3000
# Clave secreta aleatoria: ejecuta en terminal: openssl rand -base64 32
NEXTAUTH_SECRET=CAMBIAR_POR_CLAVE_ALEATORIA_SEGURA

# --- GOOGLE GEMINI (ChatBot) ---
# aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
